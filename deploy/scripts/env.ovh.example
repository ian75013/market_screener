SSH_USER=ubuntu
SSH_HOST=your.ovh.server
SSH_PORT=22
SSH_KEY_PATH=~/.ssh/id_rsa

APP_DIR=/opt/market_screener
# Use this file as the source of truth copied to remote .env during OVH deploy.
LOCAL_ENV_FILE=deploy/scripts/env.ovh

API_DOMAIN=api.market.screener.doctumconsilium.com
APP_DOMAIN=market.screener.doctumconsilium.com

POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_HOST_PORT=5432
BACKEND_BIND_HOST=127.0.0.1
BACKEND_HOST_PORT=18000
FRONTEND_BIND_HOST=127.0.0.1
FRONTEND_HOST_PORT=13000

# Optional DNS source if you keep AIRFLOW_BIND_HOST=auto.
AIRFLOW_BIND_DOMAIN=doctumconsilium.com

# Production/VPS: Airflow on OpenVPN only.
# OpenVPN example: 10.8.0.1
AIRFLOW_BIND_HOST=10.8.0.1
AIRFLOW_REQUIRE_VPN=true
AIRFLOW_PORT=18088
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change-me-prod
AIRFLOW_ADMIN_FIRSTNAME=Market
AIRFLOW_ADMIN_LASTNAME=Screener
AIRFLOW_ADMIN_EMAIL=admin@doctumconsilium.com
AIRFLOW_INTRADAY_CRON='*/30 6-22 * * 1-5'
AIRFLOW_INTRADAY_MIN_REQUIRED=8
AIRFLOW_INTRADAY_FETCH_MIN_VALID=24
AIRFLOW_INTRADAY_PROVIDER_RETRIES=2
AIRFLOW_INTRADAY_PROVIDER_RETRY_DELAY_SECONDS=2
AIRFLOW_NIGHTLY_CRON='15 2 * * 1-5'
AIRFLOW_NIGHTLY_MIN_REQUIRED=20
AIRFLOW_NIGHTLY_FETCH_MIN_VALID=50
AIRFLOW_NIGHTLY_PROVIDER_RETRIES=4
AIRFLOW_NIGHTLY_PROVIDER_RETRY_DELAY_SECONDS=3

# Set this to your public API URL for frontend build.
VITE_API_URL=https://api.market.screener.doctumconsilium.com/api/v1

# Startup refresh tuning (recommended for modest VPS)
STARTUP_MIN_REQUIRED=5
STARTUP_FETCH_MIN_VALID=25
STARTUP_PROVIDER_RETRIES=2
STARTUP_PROVIDER_RETRY_DELAY_SECONDS=2.0
STARTUP_INCLUDE_ALPACA_FALLBACK=true
STARTUP_ENABLE_TECHNICAL_FALLBACK=true
STARTUP_TOPUP_ROUNDS=8
STARTUP_TOPUP_INTERVAL_SECONDS=90
FUNDAMENTALS_ENABLED=true
FUNDAMENTALS_BOOTSTRAP_ROUNDS=10
FUNDAMENTALS_BOOTSTRAP_INITIAL_DELAY_SECONDS=300
FUNDAMENTALS_BOOTSTRAP_INTERVAL_SECONDS=120
FUNDAMENTALS_MAINTENANCE_INTERVAL_SECONDS=1800
FUNDAMENTALS_ROUND_LIMIT=140
FUNDAMENTALS_ONLY_MISSING=true

APACHE_AUTOCONFIG=false
CERTBOT_AUTOCONFIG=false
CERTBOT_EMAIL=admin@doctumconsilium.com
FORCE_HTTP_ONLY=false
AUTO_CERTBOT_ONCE=true

DEPLOY_WAIT_TIMEOUT=300
ROLLBACK_ON_FAILURE=true
AUTO_PORT_REMAP=false