APP_NAME=market-screener
IMAGE_TAG=latest

# Current kubectl context pointing to your k3s cluster
KUBE_CONTEXT=

# Images must exist in a registry reachable by k3s nodes
K8S_API_IMAGE=registry.example.com/market-screener-api:latest
K8S_STREAMLIT_IMAGE=registry.example.com/market-screener-frontend:latest
